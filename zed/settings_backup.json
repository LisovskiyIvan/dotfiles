// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "edit_predictions": {
    "open_ai_compatible_api": {
      "max_output_tokens": 64
    }
  },
  "inlay_hints": {
    "enabled": true
  },
  "vim": {
    "toggle_relative_line_numbers": false
  },
  "lsp": {
    "vtsls": {
      "settings": {
        "typescript": {
          "updateImportsOnFileMove": {
            "enabled": "always"
          }
        },
        "javascript": {
          "updateImportsOnFileMove": {
            "enabled": "always"
          }
        }
      },
      "enable_lsp_tasks": true
    }
  },
  "relative_line_numbers": "enabled",
  "ui_font_family": ".ZedSans",
  "buffer_font_family": ".ZedMono",
  "terminal": {
    "shell": {
      "program": "bash",
    },
  },
  "vim_mode": true,
  "buffer_font_weight": 400.0,
  "telemetry": {
    "diagnostics": true,
    "metrics": true,
  },
  "minimap": {
    "max_width_columns": 80,
    "current_line_highlight": "all",
    "thumb_border": "full",
    "thumb": "always",
    "show": "never",
  },
  "cursor_blink": true,
  "autosave": {
    "after_delay": {
      "milliseconds": 500,
    },
  },
  "file_types": {},
  "soft_wrap": "editor_width",
  "icon_theme": "Catppuccin Latte",
  "base_keymap": "Cursor",
  "ui_font_size": 16,
  "buffer_font_size": 15.0,
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Catppuccin Macchiato (Blur) [Light]",
  },"language_models": {
      "openai": {
        "version": 1,
        "api_url": "https://api.z.ai/api/paas/v4",
        "api_key": "твой_ключ_сюда_zai_sk-XXXXXXXXXXXXXXXXXXXXXXXX",  // ← вставь сюда
        "available_models": [
          {
            "name": "glm-4.7",
            "display_name": "GLM-4.7 (Z.ai)",
            "max_tokens": 200000
          },
          {
            "name": "glm-4.6",
            "display_name": "GLM-4.6 (Z.ai)",
            "max_tokens": 128000
          },
          {
            "name": "glm-4.5",
            "display_name": "GLM-4.5 (Z.ai)",
            "max_tokens": 128000
          },
          {
            "name": "glm-4.5-air",
            "display_name": "GLM-4.5-Air (быстрее и дешевле)",
            "max_tokens": 128000
          }
        ],
        "low_speed_timeout_in_seconds": 300
      }
    },
  
    "assistant": {
      "version": 2,
      "default_model": {
        "provider": "openai",
        "model": "glm-4.7"
      }
    }
}
