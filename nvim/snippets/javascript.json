{
    "Console Log": {
        "prefix": "cl",
        "body": [
            "console.log($1);"
        ],
        "description": "Quick console.log"
    },
    "Console warn": {
        "prefix": "cw",
        "body": [
            "console.warn($1);"
        ],
        "description": "Quick console.warn"
    },
    "Console Time": {
        "prefix": "ct",
        "body": [
            "console.time('${1:label}');"
        ],
        "description": "Quick console.time"
    },
    "Console TimeEnd": {
        "prefix": "cte",
        "body": [
            "console.timeEnd('${1:label}');"
        ],
        "description": "Quick console.timeEnd"
    },
    "Arrow Function": {
        "prefix": "af",
        "body": [
            "const ${1:functionName} = (${2:params}) => {",
            "\t$0",
            "};"
        ],
        "description": "Arrow function"
    },
